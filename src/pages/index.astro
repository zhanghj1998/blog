---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostCard from "@/components/PostCard.astro";
import { SITE } from "@/utils/constants";
import NewsBanner from "@/components/NewsBanner.astro";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 5);

const tagCounts: Record<string, number> = {};
for (const post of allPosts) {
  for (const tag of post.data.tags) {
    tagCounts[tag] = (tagCounts[tag] || 0) + 1;
  }
}
const tags = Object.entries(tagCounts)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-accent-50 via-white to-purple-50 dark:from-gray-950 dark:via-gray-900 dark:to-accent-950">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-accent-100/40 via-transparent to-transparent dark:from-accent-800/20"></div>
    <div class="relative max-w-5xl mx-auto px-4 py-32 text-center">
      <h1 class="text-5xl font-extrabold text-gray-900 dark:text-gray-100 mb-6 tracking-tight leading-tight">
        {SITE.title}
      </h1>
      <p class="text-xl text-gray-500 dark:text-gray-400 leading-relaxed max-w-lg mx-auto">
        {SITE.description}
      </p>
      <div class="mt-10 flex items-center justify-center gap-4">
        <a href="/posts" class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-accent-600 text-white font-medium hover:bg-accent-700 transition-colors no-underline shadow-lg shadow-accent-600/20">
          阅读文章
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
        <a href="/about" class="inline-flex items-center gap-2 px-6 py-3 rounded-full border border-gray-300 dark:border-gray-700 text-gray-700 dark:text-gray-300 font-medium hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors no-underline">
          关于我
        </a>
      </div>
    </div>
  </section>

  {SITE.showAINews && <NewsBanner />}

  <!-- 最新文章 -->
  <section class="max-w-5xl mx-auto px-4 py-20">
    <div class="flex items-center gap-3 mb-10">
      <span class="h-8 w-1 rounded-full bg-accent-500"></span>
      <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">最新文章</h2>
    </div>
    {posts.length > 0 ? (
      <div>
        {posts.map((post) => <PostCard {post} />)}
        {allPosts.length > 5 && (
          <div class="pt-8 text-center">
            <a href="/posts" class="inline-flex items-center gap-2 text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 font-medium no-underline">
              查看全部 {allPosts.length} 篇文章
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        )}
      </div>
    ) : (
      <p class="text-gray-400 dark:text-gray-500">还没有文章。</p>
    )}
  </section>

  <!-- 标签 -->
  {tags.length > 0 && (
    <section class="max-w-5xl mx-auto px-4 pb-24">
      <div class="flex items-center gap-3 mb-10">
        <span class="h-8 w-1 rounded-full bg-purple-500"></span>
        <h2 class="text-2xl font-bold text-gray-900 dark:text-gray-100">标签</h2>
      </div>
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <a
            href={`/tags/${tag}`}
            class="inline-flex items-center gap-1.5 px-4 py-2 text-sm rounded-full bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 text-gray-700 dark:text-gray-300 hover:border-accent-300 dark:hover:border-accent-700 hover:text-accent-600 dark:hover:text-accent-400 transition-colors no-underline shadow-sm"
          >
            {tag}
            <span class="text-xs text-gray-400 dark:text-gray-500 bg-gray-100 dark:bg-gray-700 px-1.5 py-0.5 rounded-full">{count}</span>
          </a>
        ))}
        <a href="/tags" class="inline-flex items-center px-4 py-2 text-sm rounded-full text-gray-400 hover:text-accent-600 dark:hover:text-accent-400 transition-colors no-underline">
          全部标签 &rarr;
        </a>
      </div>
    </section>
  )}
</BaseLayout>
