---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="页面不存在">
  <div class="max-w-5xl mx-auto px-4 py-24 text-center">
    <h1 class="text-6xl font-bold text-gray-300 dark:text-gray-700 mb-4">404</h1>
    <p class="text-lg text-gray-500 dark:text-gray-400 mb-8">你访问的页面不存在。</p>
    <a href="/" class="text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-gray-100 font-medium no-underline">
      &larr; 返回首页
    </a>
  </div>
</BaseLayout>
