---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatDate } from "@/utils/dateFormat";
import { readingTime } from "@/utils/readingTime";
import TagBadge from "@/components/TagBadge.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"posts">;
}

const { post } = Astro.props;
const { title, date, description, tags } = post.data;
const body = post.body || "";
const minutes = readingTime(body);
---

<BaseLayout title={title} description={description} type="article">
  <article class="max-w-5xl mx-auto px-4 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-extrabold text-gray-900 dark:text-gray-100 mb-6 leading-tight tracking-tight">
        {title}
      </h1>
      <div class="flex flex-wrap items-center gap-3 text-sm text-gray-400 dark:text-gray-500 mb-6">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        <span class="w-1 h-1 rounded-full bg-gray-300 dark:bg-gray-600"></span>
        <span>阅读约 {minutes} 分钟</span>
      </div>
      {
        tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => <TagBadge tag={tag} />)}
          </div>
        )
      }
    </header>
    <div class="prose prose-gray dark:prose-invert max-w-none leading-relaxed prose-headings:font-bold prose-a:text-accent-600 dark:prose-a:text-accent-400 prose-code:before:content-none prose-code:after:content-none">
      {post.body}
    </div>
    <div class="mt-16 pt-8 border-t border-gray-100 dark:border-gray-800">
      <a href="/posts" class="inline-flex items-center gap-2 text-accent-600 dark:text-accent-400 hover:text-accent-700 dark:hover:text-accent-300 font-medium no-underline">
        &larr; 返回文章列表
      </a>
    </div>
  </article>
</BaseLayout>
