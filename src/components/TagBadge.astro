---
const { tag } = Astro.props as { tag: string };
---

<a
  href={`/tags/${tag}`}
  class="inline-block px-2.5 py-0.5 text-xs font-medium rounded-full bg-accent-50 dark:bg-accent-900/30 text-accent-700 dark:text-accent-300 hover:bg-accent-100 dark:hover:bg-accent-900/50 transition-colors no-underline"
>
  {tag}
</a>
